import os
import pandas as pd

def read_wos_batch(folder_path):
    records = []
    for fn in os.listdir(folder_path):
        if fn.endswith(".txt"):
            fp = os.path.join(folder_path, fn)
            with open(fp, "r", encoding="utf-8", errors="ignore") as f:
                lines = f.readlines()
            rec = {}
            for line in lines:
                line = line.strip()
                if len(line) < 3:
                    continue
                fd = line[:2]
                val = line[3:].strip()
                if fd == "PT":
                    if rec:
                        records.append(rec)
                    rec = {}
                if fd in ["TI", "AU", "SO", "DE", "PY", "C1"]:
                    if fd in rec:
                        rec[fd] += "; " + val
                    else:
                        rec[fd] = val
            if rec:
                records.append(rec)

    df = pd.DataFrame(records)
    df.rename(columns={
        "TI": "标题",
        "AU": "作者",
        "SO": "期刊",
        "DE": "关键词",
        "PY": "年份",
        "C1": "机构"
    }, inplace=True)
    return df
import pandas as pd

def clean_data(df, source="wos"):
    df = df.copy()
    df = df.dropna(subset=["关键词", "年份"])
    df = df[df["关键词"].str.len() > 1]
    df["年份"] = pd.to_numeric(df["年份"], errors="coerce")
    df = df[df["年份"] >= 1900]
    return df
import pandas as pd

def calc_basic_indices(df):
    total = len(df)
    year_cnt = df["年份"].value_counts().sort_index().to_dict()
    auth_cnt = df["作者"].str.split("; ").explode().value_counts().head(10).to_dict()
    kw_cnt = df["关键词"].str.split("; ").explode().value_counts().head(10).to_dict()
    journal_cnt = df["期刊"].value_counts().head(10).to_dict()

    return {
        "总文献量": total,
        "年度发文量": year_cnt,
        "高产作者TOP10": auth_cnt,
        "高频关键词TOP10": kw_cnt,
        "高发文期刊TOP10": journal_cnt
    }
import pandas as pd
from collections import defaultdict

def build_co_occurrence(df, top_n=50):
    kw_series = df["关键词"].str.split("; ").dropna()
    all_kw = kw_series.explode().value_counts().head(top_n).index.tolist()

    matrix = pd.DataFrame(0, index=all_kw, columns=all_kw)
    for kws in kw_series:
        kws = [k for k in kws if k in all_kw]
        for i in range(len(kws)):
            for j in range(i + 1, len(kws)):
                a, b = kws[i], kws[j]
                matrix.loc[a, b] += 1
                matrix.loc[b, a] += 1
    return matrix, all_kw
import networkx as nx
import community as community_louvain
import pandas as pd

def cluster_network(matrix, threshold=2):
    G = nx.Graph()
    for i in range(len(matrix)):
        for j in range(i + 1, len(matrix)):
            w = matrix.iloc[i, j]
            if w >= threshold:
                G.add_edge(matrix.index[i], matrix.columns[j], weight=w)

    partition = community_louvain.best_partition(G, resolution=1.0)
    nx.set_node_attributes(G, partition, "cluster")

    stats = []
    for cid in set(partition.values()):
        nodes = [n for n, c in partition.items() if c == cid]
        sg = G.subgraph(nodes)
        stats.append({
            "聚类ID": cid,
            "节点数": len(nodes),
            "密度": round(nx.density(sg), 3),
            "中心关键词": max(nodes, key=lambda x: sg.degree(x)) if nodes else ""
        })
    return G, partition, pd.DataFrame(stats)
