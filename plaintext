from pyvis.network import Network
import config

def interactive_cluster_graph(G, partition, path=f"{config.OUTPUT_HTML}/keyword_graph.html"):
    net = Network(height="750px", width="100%", bgcolor="#222", font_color="white")
    net.force_atlas_2based()

    colors = ["#1f77b4", "#ff7f0e", "#2ca02c", "#d62728", "#9467bd", "#8c564b"]
    for node in G.nodes:
        c = partition[node]
        net.add_node(
            node,
            color=colors[c % len(colors)],
            size=G.degree(node) * 3 + 10,
            title=f"关键词：{node}\n聚类：{c}"
        )

    for u, v, d in G.edges(data=True):
        net.add_edge(u, v, width=d["weight"] / 3, title=f"共现：{d['weight']}")

    net.show(path, notebook=False)
